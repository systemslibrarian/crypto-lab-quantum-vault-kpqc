# ------------------------------
# Rust / Cargo
# ------------------------------
/target/
**/target/
# NOTE: Cargo.lock IS committed — required for reproducible builds (this is an app, not a library)

# ------------------------------
# Node / Next.js
# ------------------------------
node_modules/
.next/
out/
dist/
coverage/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ------------------------------
# WASM outputs
# ------------------------------
*.wasm
*.wat
pkg/
wasm-pack.log
# wasm-pack build output (serve from public/ for the Next.js demo)
web-demo/src/lib/wasm-pkg/
web-demo/public/wasm-pkg/
# Emscripten-compiled WASM modules (committed separately to web-demo/public/)
wasm/dist/
# Keep the compiled .wasm binaries that ship with the web demo
!web-demo/public/smaug.wasm
!web-demo/public/haetae.wasm
# Keep the Emscripten JS loaders bundled into the app
!web-demo/src/crypto/wasm/smaug.js
!web-demo/src/crypto/wasm/haetae.js

# ------------------------------
# Vendor sources (large C reference implementations)
# Clone / extract them locally before running wasm/build.sh — see README
# ------------------------------
wasm/vendor/
/vendor/

# ------------------------------
# Environment files
# ------------------------------
.env
.env.*
!.env.example

